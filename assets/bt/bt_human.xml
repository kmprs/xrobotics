<?xml version="1.0" encoding="UTF-8"?>
<BehaviorTree bt_type="ROBOT">
    <Goal name="clean the kitchen counter">
        <Description value=""/>

        <Subgoal name="navigate to the kitchen counter">
            <Need value="I need to be able to reach the area that is dirty."/>
            <Description value="I navigate to the kitchen counter so I can reach the area that needs cleaning. I prepare for navigation and then move to the counter."/>

            <Step name="prepare_navigation">
                <Action name="unlock_wheels"/>
                <Action name="activate_motors"/>
            </Step>

            <Step name="move_to_counter1">
                <Action name="compute_path"/>
                <Action name="follow_path"/>
            </Step>
        </Subgoal>

    </Goal>
</BehaviorTree>
