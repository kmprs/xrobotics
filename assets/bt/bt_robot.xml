<?xml version="1.0" encoding="UTF-8"?>
<BehaviorTree bt_type="ROBOT">
    <Goal name="clean the kitchen counter">
        <Description value="I first navigate to the kitchen counter so it can reach the work area. I then prepare the cleaning tool and wipe the surface to remove dirt and leave the counter clean."/>


        <Subgoal name="navigate to the kitchen counter">
            <Description value="I navigate to the kitchen counter so I can reach the area that needs cleaning. I prepare for navigation and then move to the counter."/>
            <Step name="prepare_navigation">
                <Action name="unlock_wheels"/>
                <Action name="activate_motors"/>
            </Step>
            <Step name="move_to_counter">
                <Action name="compute_path"/>
                <Action name="follow_path"/>
            </Step>
        </Subgoal>


        <Subgoal name="wipe the kitchen counter">
            <Description value="I wipe the kitchen counter to remove dirt and maintain a clean surface. I prepare the cleaning tool, apply cleaner, and wipe the surface."/>

            <Step name="prepare_cleaning_tool">
                <Action name="extend_arm"/>
                <Action name="grasp_cleaning_cloth"/>
            </Step>

            <Step name="apply_cleaner">
                <Action name="spray_cleaning_solution"/>
                <Action name="wait_for_solution_to_settle"/>
            </Step>

            <Step name="wipe_surface">
                <Action name="execute_wiping_pattern"/>
                <Action name="remove_debris"/>
            </Step>
        </Subgoal>
    </Goal>
</BehaviorTree>
